# PRODUCTION .env EXAMPLE
# Copy this to .env for production deployment
# WARNING: Update all sensitive values before deploying!

# ========================================
# APPLICATION CONFIGURATION
# ========================================
APP_NAME="Samer Shop"
APP_ENV=production
APP_KEY=                        # REQUIRED: Run 'php artisan key:generate'
APP_DEBUG=false                 # MUST be false in production!
APP_URL=https://api.port.samsmy.com

# ========================================
# LOGGING & MONITORING
# ========================================
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning              # production: warning, error, or critical

# ========================================
# SECURITY CONFIGURATION
# ========================================

# CORS - Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=https://dashboard.port.samsmy.com,https://www.samsmy.com

# Sanctum Configuration
SANCTUM_EXPIRATION=1440                              # 24 hours
SANCTUM_STATEFUL_DOMAINS=dashboard.port.samsmy.com
SESSION_DOMAIN=.port.samsmy.com                      # Include subdomain

# ========================================
# DATABASE CONFIGURATION
# ========================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1              # Or your DB server IP
DB_PORT=3306
DB_DATABASE=samer_shop_production
DB_USERNAME=laravel_user        # DO NOT use root!
DB_PASSWORD=                    # STRONG PASSWORD REQUIRED!

# ========================================
# CACHE & SESSION
# ========================================
BROADCAST_DRIVER=redis          # Use redis in production
CACHE_DRIVER=redis
FILESYSTEM_DISK=dashboard_storage
QUEUE_CONNECTION=redis          # Use redis for queues
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null             # Set if Redis has password
REDIS_PORT=6379

# ========================================
# MEDIA STORAGE (Dashboard Folder)
# ========================================
MEDIA_DISK=dashboard_storage
DASHBOARD_STORAGE_PATH=/var/www/dashboard.port.samsmy.com/storage
DASHBOARD_STORAGE_URL=https://dashboard.port.samsmy.com/storage

# ========================================
# MAIL CONFIGURATION (Mailgun)
# ========================================
MAIL_MAILER=mailgun
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=                  # postmaster@your-domain.com
MAIL_PASSWORD=                  # Your Mailgun SMTP password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@samsmy.com"
MAIL_FROM_NAME="${APP_NAME}"

# Mailgun API Configuration
MAILGUN_DOMAIN=                 # your-mailgun-domain.com
MAILGUN_SECRET=                 # Your Mailgun API key (starts with key-)
MAILGUN_ENDPOINT=api.mailgun.net

# ========================================
# FRONTEND CONFIGURATION
# ========================================
FRONTEND_URL=https://dashboard.port.samsmy.com

# ========================================
# OPTIONAL: AWS S3 (if using cloud storage)
# ========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ========================================
# SECURITY CHECKLIST
# ========================================
# Before deploying to production:
# [ ] Generated strong APP_KEY
# [ ] Set APP_DEBUG=false
# [ ] Set APP_ENV=production
# [ ] Updated all database credentials
# [ ] Set strong DB_PASSWORD (minimum 16 characters)
# [ ] Updated CORS_ALLOWED_ORIGINS to production domains only
# [ ] Configured SANCTUM_STATEFUL_DOMAINS
# [ ] Set correct SESSION_DOMAIN
# [ ] Updated Mailgun credentials
# [ ] Set FRONTEND_URL to production domain
# [ ] Configured Redis (recommended)
# [ ] Set MEDIA_DISK=dashboard_storage
# [ ] Updated storage paths to absolute paths
# [ ] Set correct file permissions (storage: 775, .env: 600)
# [ ] SSL certificate installed and HTTPS configured
# [ ] Firewall configured (allow only 80, 443, 22)
# [ ] Database user has minimal required permissions (not root)
# [ ] Regular backup schedule configured
# [ ] Monitoring/logging system in place
# [ ] Security headers enabled (via SecurityHeaders middleware)
